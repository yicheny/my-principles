---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '我的原则' } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="个人原则笔记" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href={base} class="site-title">我的原则</a>
      <div class="nav-links">
        <a href={`${base}work/`} class:list={[{ active: currentPath.includes('/work') }]}>工作</a>
        <a href={`${base}life/`} class:list={[{ active: currentPath.includes('/life') }]}>生活</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>持续更新中 · 用原则指导行动</p>
    </footer>
  </body>
</html>

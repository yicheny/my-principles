---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '我的原则' } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="个人原则笔记" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href={base} class="site-title">我的原则</a>
      <div class="nav-links">
        <a href={`${base}/learn/`} class:list={[{ active: currentPath.includes('/learn') }]}>学习</a>
        <a href={`${base}/principles/`} class:list={[{ active: currentPath.includes('/principles') }]}>原则</a>
        <a href={`${base}/daily/`} class:list={[{ active: currentPath.includes('/daily') }]}>每日</a>
        <a href={`${base}/notes/`} class:list={[{ active: currentPath.includes('/notes') }]}>笔记</a>
        <a href={`${base}/keyPoints/`} class:list={[{ active: currentPath.includes('/keyPoints') }]}>速查</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>持续更新中 · 用原则指导行动</p>
    </footer>
  </body>
</html>

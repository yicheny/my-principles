---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const learnPrinciples = (await getCollection('learn')).sort((a, b) => a.data.order - b.data.order);
const principles = (await getCollection('principles')).sort((a, b) => a.data.order - b.data.order);
const dailyEntries = (await getCollection('daily')).sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 5);
---

<Base title="我的原则">
  <div class="hero">
    <h1>我的原则</h1>
    <p>记录工作与生活中的核心准则，用来指导决策和行动。</p>
  </div>

  <h2 class="section-title">⚡ 原则</h2>
  <div class="card-list">
    {principles.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {principles.map((entry) => (
      <a href={`${base}/principles/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <h2 class="section-title">📚 学习原则</h2>
  <div class="card-list">
    {learnPrinciples.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {learnPrinciples.map((entry) => (
      <a href={`${base}/learn/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <h2 class="section-title">📝 每日学习</h2>
  <div class="card-list">
    {dailyEntries.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {dailyEntries.map((entry) => (
      <a href={`${base}/daily/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        <p style="color: var(--color-text-secondary); font-size: 0.85rem; margin-top: 0.25rem;">{entry.data.date}</p>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</Base>

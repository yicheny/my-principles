---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const workPrinciples = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const lifePrinciples = (await getCollection('life')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="我的原则">
  <div class="hero">
    <h1>我的原则</h1>
    <p>记录工作与生活中的核心准则，用来指导决策和行动。</p>
  </div>

  <h2 class="section-title">🔧 工作原则</h2>
  <div class="card-list">
    {workPrinciples.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {workPrinciples.map((entry) => (
      <a href={`${base}work/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <h2 class="section-title">🌱 生活原则</h2>
  <div class="card-list">
    {lifePrinciples.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {lifePrinciples.map((entry) => (
      <a href={`${base}life/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</Base>

---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('notes')).sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Base title="学习笔记">
  <a href={base} class="back-link">&larr; 返回首页</a>
  <h2 class="section-title">📒 学习笔记</h2>
  <div class="card-list">
    {entries.length === 0 && <p style="color: var(--color-text-secondary)">暂无内容</p>}
    {entries.map((entry) => (
      <a href={`${base}/notes/${entry.id}/`} class="card">
        <h3>{entry.data.title}</h3>
        <p class="meta">{entry.data.date}</p>
        {entry.data.tags.length > 0 && (
          <div class="tags">
            {entry.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</Base>

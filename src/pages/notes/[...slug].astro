---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL;
const tocHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 4);

---

<Base title={`${entry.data.title} - 学习笔记`}>
  {tocHeadings.length > 0 && (
    <button class="toc-toggle" aria-label="目录">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="5" x2="17" y2="5" />
        <line x1="3" y1="10" x2="13" y2="10" />
        <line x1="3" y1="15" x2="17" y2="15" />
      </svg>
    </button>
  )}
  {tocHeadings.length > 0 && (
    <div class="toc-overlay"></div>
  )}
  {tocHeadings.length > 0 && (
    <aside class="toc">
      <div class="toc-header">
        <p class="toc-title">目录</p>
        <div class="toc-depth-btns">
          <button class="toc-depth-btn active" data-max="0">全</button>
          <button class="toc-depth-btn" data-max="1">1</button>
          <button class="toc-depth-btn" data-max="2">2</button>
          <button class="toc-depth-btn" data-max="3">3</button>
          <button class="toc-depth-btn" data-max="4">4</button>
        </div>
      </div>
      <ul>
        {tocHeadings.map(h => (
          <li data-depth={h.depth}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )}
  <div class="article-nav">
    <a href={`${base}/notes/`} class="back-link">&larr; 返回学习笔记</a>
    <button class="print-btn" onclick="window.print()">导出 PDF</button>
  </div>
  <article>
    <h1>{entry.data.title}</h1>
    {entry.data.tags.length > 0 && (
      <div class="tags">
        {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
    <p class="meta">{entry.data.date} · 全文 <span id="word-count">…</span> 字</p>
    <div class="content">
      <Content />
    </div>
  </article>
</Base>

<script>
  // 字数统计：从渲染后的 DOM 读取文章文本，中文每字计1，英文每词计1
  const articleContent = document.querySelector('article .content');
  const wordCountEl = document.getElementById('word-count');
  if (articleContent && wordCountEl) {
    const text = articleContent.textContent ?? '';
    const cjk = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) ?? []).length;
    const en = (text.match(/[a-zA-Z]+/g) ?? []).length;
    wordCountEl.textContent = String(cjk + en);
  }

  // TOC depth filter
  const depthBtns = document.querySelectorAll<HTMLButtonElement>('.toc-depth-btn');
  const tocItems = document.querySelectorAll<HTMLElement>('.toc li[data-depth]');
  depthBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      depthBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const max = Number(btn.dataset.max);
      tocItems.forEach(li => {
        const depth = Number(li.dataset.depth);
        li.style.display = (max === 0 || depth <= max) ? '' : 'none';
      });
    });
  });

  // TOC toggle for mobile
  const tocToggle = document.querySelector('.toc-toggle');
  const toc = document.querySelector('.toc');
  const tocOverlay = document.querySelector('.toc-overlay');

  if (tocToggle && toc && tocOverlay) {
    const openToc = () => {
      toc.classList.add('open');
      tocOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    };
    const closeToc = () => {
      toc.classList.remove('open');
      tocOverlay.classList.remove('open');
      document.body.style.overflow = '';
    };
    tocToggle.addEventListener('click', () => {
      toc.classList.contains('open') ? closeToc() : openToc();
    });
    tocOverlay.addEventListener('click', closeToc);
    toc.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', closeToc);
    });
  }

  // IntersectionObserver for active heading
  const headings = Array.from(document.querySelectorAll('article h1, article h2, article h3'));
  const links = document.querySelectorAll('.toc a');
  if (headings.length && links.length) {
    const observer = new IntersectionObserver(
      () => {
        const top = headings
          .filter(h => h.getBoundingClientRect().top <= 120)
          .at(-1) ?? headings[0];
        links.forEach(a => a.classList.remove('active'));
        if (top) {
          const active = document.querySelector(`.toc a[href="#${top.id}"]`);
          active?.classList.add('active');
        }
      },
      { rootMargin: '0px 0px -80% 0px' }
    );
    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  article .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.5rem 0 0.75rem;
  }
  article .tag {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: var(--color-tag-bg);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .toc-header .toc-title { margin-bottom: 0; }
  .toc-depth-btns {
    display: flex;
    gap: 0.2rem;
  }
  .toc-depth-btn {
    padding: 0.1rem 0.35rem;
    font-size: 0.7rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    line-height: 1.4;
  }
  .toc-depth-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .print-btn {
    padding: 0.35rem 0.9rem;
    font-size: 0.85rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
  }
  .print-btn:hover { background: var(--color-tag-bg); }

  @media print {
    :global(nav), :global(footer),
    .toc, .toc-toggle, .toc-overlay,
    .article-nav, #word-count {
      display: none !important;
    }
    :global(body) { background: white; }
    :global(main) { max-width: none; padding: 0; margin: 0; }
    article { padding: 0; }
    :global(pre) {
      white-space: pre-wrap;
      page-break-inside: avoid;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    h2, h3 { page-break-after: avoid; }
  }
</style>
